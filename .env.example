# ── Supabase (already yours — from your Supabase project dashboard) ──────────
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# ── Gemini AI (free — get from https://aistudio.google.com/apikey) ──────────
# Free tier: 1 million tokens/day on Gemini Flash = ~5000+ chat messages/day for free
# No credit card required to start
VITE_GEMINI_API_KEY="your-gemini-api-key-here"

# Unsplash API key for fashion image search
VITE_UNSPLASH_ACCESS_KEY="your-unsplash-access-key-here"
